# Dr. Priyal Agarwal — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO / canonical / OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — PUBLIC (safe in the browser; constrained by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://baujdadxiaeyhcpkbvhu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase — SECRET (server-only; bypasses RLS). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (server-side secret + public key id)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# 100ms video (server-side)
HMS_ACCESS_KEY=your-100ms-access-key
HMS_SECRET=your-100ms-secret
HMS_TEMPLATE_ID=your-100ms-template-id

# Email (Resend) + SMS/WhatsApp (MSG91 / WhatsApp Cloud API)
RESEND_API_KEY=your-resend-key
MSG91_AUTH_KEY=your-msg91-key
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-id
